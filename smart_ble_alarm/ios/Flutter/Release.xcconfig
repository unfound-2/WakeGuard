#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.release.xcconfig"
#include "Generated.xcconfig"

// See Debug.xcconfig: ML Kit's MLImage has no arm64-simulator slice, so the
// simulator must build x86_64 under Rosetta. Simulator-scoped — device/archive
// builds keep arm64 and are unaffected.
EXCLUDED_ARCHS[sdk=iphonesimulator*] = arm64 i386
